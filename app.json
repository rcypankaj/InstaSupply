{
  "expo": {
    "name": "InstaSupply Driver",
    "slug": "instasupply",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "instasupply",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A73E8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.instasupply.driver",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "package": "com.instasupply.driver",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#1A73E8",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "src/app"
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-monochrome.png",
          "color": "#1A73E8",
          "defaultChannel": "deliveries"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow InstaSupply Driver to access your location for route navigation."
        }
      ],
      [
        "react-native-maps",
        {
          "googleMapsApiKey": "AIzaSyD9tHpCUbn1m9SXwKCaYUU_c9tABgJHQFc"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "router": {
        "root": "src/app"
      },
      "eas": {
        "projectId": "750d0686-1a47-483e-9a39-8979f0ef7c07"
      }
    }
  }
}
